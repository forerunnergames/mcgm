# Anthropic API key for the LLM brain.
ANTHROPIC_API_KEY=sk-ant-...

# Pterodactyl panel client API for executing in-game commands.
# (Works with any Pterodactyl-based hosting provider.)
PANEL_API_KEY=ptlc_...
PANEL_API_BASE=https://panel.example.com/api/client
PANEL_SERVER_ID=your-server-id

# Server connection (Geyser endpoint, UDP).
SERVER_HOST=0.0.0.0
SERVER_PORT=9025

# Bedrock client version to advertise.
BEDROCK_VERSION=1.21.124

# Only this player can trigger world actions through the bot.
AUTHORIZED_OP=.your-bedrock-username

# The bot's in-game name (Bedrock gamertag with leading dot).
BOT_NAME=.your-bot-username

# Claude model.
LLM_MODEL=claude-sonnet-4-6

# Web UI — phone chat interface.
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=3000

# Nintendo Switch player — auto-teleported away during large block operations
# to prevent client freezing. Leave blank if no Switch players.
SWITCH_PLAYER=.your-switch-username
