# Anthropic API key for the LLM brain.
ANTHROPIC_API_KEY=sk-ant-...

# Bisect Starbase / Pterodactyl client API for executing in-game commands.
BISECT_API_KEY=ptlc_...
BISECT_API_BASE=https://games.bisecthosting.com/api/client
BISECT_SERVER_ID=your-server-id

# Server connection (Geyser endpoint, UDP).
SERVER_HOST=0.0.0.0
SERVER_PORT=9025

# Bedrock client version to advertise.
BEDROCK_VERSION=1.21.124

# Only this player can trigger world actions through the bot.
AUTHORIZED_OP=.your-bedrock-username

# Claude model.
LLM_MODEL=claude-sonnet-4-6

# Web UI — phone chat interface.
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=3000
